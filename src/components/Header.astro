---
import { GITHUB_URL, SITE_TITLE, withBase } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Logo from './Logo.astro';
---

<header>
	<div class="rail">
		<a href={withBase('/')} class="brand">
			<Logo size={30} />
			<span>{SITE_TITLE}</span>
		</a>
		<nav class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">笔记</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</nav>
		<div class="bottom">
			<a href={GITHUB_URL} target="_blank">GitHub ↗</a>
		</div>
	</div>
</header>
<style>
	header {
		border-right: 1.5px solid var(--ink);
		background: rgba(255, 255, 255, 0.55);
		backdrop-filter: blur(2px);
	}
	.rail {
		position: sticky;
		top: 0;
		height: 100vh;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		padding: 2.2em 1.5em;
		gap: 2.2em;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.5em;
		color: var(--ink);
		text-decoration: none;
		font-weight: 700;
		font-size: 1.02em;
	}
	.internal-links {
		display: flex;
		flex-direction: column;
		gap: 0.7em;
		font-size: 0.9em;
	}
	.internal-links :global(a) {
		color: var(--dim);
		text-decoration: none;
	}
	.internal-links :global(a:hover) {
		color: var(--ink);
	}
	.internal-links :global(a.active) {
		color: var(--ink);
		font-weight: 700;
	}
	.internal-links :global(a.active)::before {
		content: '';
		display: inline-block;
		width: 7px;
		height: 7px;
		background: var(--accent);
		border-radius: 50%;
		margin-right: 0.55em;
		vertical-align: 1px;
	}
	.bottom {
		margin-top: auto;
		font-size: 0.8em;
	}
	.bottom a {
		color: var(--faint);
		text-decoration: none;
	}
	.bottom a:hover {
		color: var(--ink);
	}
	@media (max-width: 720px) {
		header {
			border-right: none;
			border-bottom: 1.5px solid var(--ink);
		}
		.rail {
			position: static;
			height: auto;
			flex-direction: row;
			align-items: center;
			padding: 0.9em 1.2em;
			gap: 1.5em;
		}
		.internal-links {
			flex-direction: row;
			gap: 1.2em;
		}
		.bottom {
			margin-top: 0;
			margin-left: auto;
		}
	}
</style>
