---
import { GITHUB_URL, SITE_TITLE, withBase } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Logo from './Logo.astro';
---

<header>
	<nav>
		<h2>
			<a href={withBase('/')} class="brand">
				<Logo size={26} />
				<span class="path"><span class="tilde">~/</span>{SITE_TITLE}</span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">笔记</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
		<div class="social-links">
			<a href={GITHUB_URL} target="_blank">
				<span class="sr-only">GitHub 仓库</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(13, 17, 23, 0.9);
		backdrop-filter: blur(6px);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	h2 {
		margin: 0;
		font-size: 1em;
		font-weight: 400;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.5em;
		color: var(--heading);
	}
	.tilde {
		color: var(--accent);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 760px;
		margin: 0 auto;
	}
	nav a {
		padding: 0.8em 0.5em;
		color: var(--text);
		text-decoration: none;
		font-size: 0.95em;
	}
	nav a:hover {
		color: var(--accent);
	}
	nav a.active {
		color: var(--accent);
	}
	.internal-links a.active::before {
		content: '> ';
	}
	.social-links,
	.social-links a {
		display: flex;
		color: var(--dim);
	}
	.social-links a:hover {
		color: var(--heading);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
