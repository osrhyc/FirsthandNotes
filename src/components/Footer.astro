---
import { GITHUB_URL, SITE_TITLE, SITE_TITLE_EN, withBase } from '../consts';

const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} {SITE_TITLE} · {SITE_TITLE_EN}</span>
	<div class="links">
		<a href={withBase('/rss.xml')}>RSS</a>
		<a href={GITHUB_URL} target="_blank">GitHub</a>
	</div>
</footer>
<style>
	footer {
		padding: 1.2em 3em 2em;
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		flex-wrap: wrap;
		color: var(--faint);
		font-size: 0.8em;
		border-top: 1px dashed var(--faint);
		max-width: 760px;
		box-sizing: border-box;
	}
	.links {
		display: flex;
		gap: 1.4em;
	}
	.links a {
		color: var(--faint);
		text-decoration: none;
	}
	.links a:hover {
		color: var(--ink);
	}
	@media (max-width: 720px) {
		footer {
			padding: 1.2em 1.2em 2em;
		}
	}
</style>
