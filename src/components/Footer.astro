---
import { GITHUB_URL, SITE_TITLE, SITE_TITLE_EN, withBase } from '../consts';

const today = new Date();
---

<footer>
	<p>
		<span class="comment">// &copy; {today.getFullYear()} {SITE_TITLE} · {SITE_TITLE_EN}</span>
	</p>
	<div class="links">
		<a href={withBase('/rss.xml')}>rss</a>
		<span class="sep">|</span>
		<a href={GITHUB_URL} target="_blank">github</a>
		<span class="sep">|</span>
		<a href="https://astro.build/" target="_blank">astro</a>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 3em;
		border-top: 1px solid var(--border);
		color: var(--dim);
		text-align: center;
		font-size: 0.85em;
	}
	footer p {
		margin: 0 0 0.4em;
	}
	.comment {
		color: var(--dim);
	}
	.links {
		display: flex;
		justify-content: center;
		gap: 0.8em;
	}
	.links a {
		color: var(--dim);
		text-decoration: none;
	}
	.links a:hover {
		color: var(--accent);
	}
	.sep {
		color: var(--border);
	}
</style>
