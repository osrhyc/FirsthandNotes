---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Logo from '../components/Logo.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE, SITE_TITLE_EN, withBase } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${SITE_TITLE} · ${SITE_TITLE_EN}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<Logo size={96} class="hero-logo" />
				<h1>{SITE_TITLE}</h1>
				<p class="en-name">{SITE_TITLE_EN}</p>
				<p class="slogan"><span class="rule"></span>{SITE_DESCRIPTION}<span class="rule"></span></p>
				<ul class="categories">
					{CATEGORIES.map((c) => <li>{c}</li>)}
				</ul>
			</section>
			<section class="recent">
				<h2>最新文章</h2>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={withBase(`/blog/${post.id}/`)}>
									<span class="post-title">{post.data.title}</span>
									<span class="post-meta">
										{post.data.category && <span class="category">{post.data.category}</span>}
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))
					}
				</ul>
				<p class="all-posts"><a href={withBase('/blog')}>查看全部文章 →</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 2.5em 0 3em;
	}
	.hero h1 {
		margin: 0.4em 0 0;
		letter-spacing: 0.12em;
	}
	.en-name {
		margin: 0;
		color: rgb(var(--gray-dark));
		letter-spacing: 0.35em;
		text-transform: uppercase;
		font-size: 1.05em;
	}
	.slogan {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.8em;
		margin: 1.2em 0 0;
		color: rgb(var(--gray));
		font-size: 0.95em;
		letter-spacing: 0.2em;
	}
	.rule {
		display: inline-block;
		width: 2.2em;
		height: 2px;
		background: var(--gold);
	}
	.categories {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.6em;
		list-style: none;
		margin: 1.8em 0 0;
		padding: 0;
	}
	.categories li {
		padding: 0.15em 0.9em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		background: #fff;
		color: rgb(var(--gray-dark));
		font-size: 0.8em;
	}
	.recent h2 {
		font-size: 1.4em;
		border-bottom: 2px solid var(--gold);
		display: inline-block;
		padding-bottom: 0.2em;
	}
	.post-list {
		list-style: none;
		margin: 1em 0 0;
		padding: 0;
	}
	.post-list li + li {
		border-top: 1px solid rgb(var(--gray-light));
	}
	.post-list a {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1em;
		padding: 0.7em 0.2em;
		text-decoration: none;
	}
	.post-title {
		color: rgb(var(--black));
	}
	.post-list a:hover .post-title {
		color: var(--accent-dark);
	}
	.post-meta {
		display: flex;
		align-items: baseline;
		gap: 0.8em;
		color: rgb(var(--gray));
		font-size: 0.8em;
		white-space: nowrap;
	}
	.category {
		color: var(--accent);
	}
	.all-posts {
		margin-top: 1.2em;
		text-align: right;
		font-size: 0.9em;
	}
	.all-posts a {
		text-decoration: none;
	}
	@media (max-width: 720px) {
		.post-list a {
			flex-direction: column;
			gap: 0.2em;
		}
	}
</style>
