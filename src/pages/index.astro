---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_TITLE_EN, withBase } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${SITE_TITLE} · ${SITE_TITLE_EN}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">{SITE_TITLE_EN}</p>
				<h1>{SITE_TITLE}</h1>
				<p class="standfirst">{SITE_DESCRIPTION}</p>
			</section>
			<section class="latest">
				{
					posts.length > 0 ? (
						<div class="cards">
							{posts.map((post) => (
								<a class="note-card row" href={withBase(`/blog/${post.id}/`)}>
									<span class="title">{post.data.title}</span>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							))}
						</div>
					) : (
						<div class="note-card row empty">
							<span class="title">第一篇笔记正在路上……</span>
							<span class="date">敬请期待</span>
						</div>
					)
				}
				{
					posts.length > 0 && (
						<p class="all-posts">
							<a href={withBase('/blog')}>全部笔记 →</a>
						</p>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		margin-bottom: 2.2em;
	}
	.hero h1 {
		margin: 0 0 0.15em;
	}
	.standfirst {
		color: var(--dim);
		margin: 0;
		font-size: 0.95em;
	}
	.cards {
		display: flex;
		flex-direction: column;
		gap: 0.9em;
	}
	.row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1.2em;
		padding: 0.7em 1.1em;
		font-size: 0.95em;
	}
	.title {
		font-weight: 700;
	}
	.date {
		color: var(--faint);
		font-size: 0.82em;
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}
	.empty .title {
		color: var(--dim);
		font-weight: 400;
	}
	.all-posts {
		margin-top: 1.8em;
		font-size: 0.9em;
	}
	.all-posts a {
		text-decoration: none;
		font-weight: 700;
	}
	.all-posts a:hover {
		text-decoration: underline;
	}
	@media (max-width: 720px) {
		.row {
			flex-direction: column;
			gap: 0.1em;
		}
	}
</style>
