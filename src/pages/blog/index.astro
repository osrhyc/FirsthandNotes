---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, withBase } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-title {
				font-size: 1.4em;
				border-bottom: 2px solid var(--gold);
				display: inline-block;
				padding-bottom: 0.2em;
				margin-bottom: 1em;
			}
			ul {
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li + li {
				border-top: 1px solid rgb(var(--gray-light));
			}
			ul li a {
				display: block;
				padding: 1em 0.2em;
				text-decoration: none;
			}
			ul li img {
				margin-bottom: 0.5em;
				border-radius: 12px;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.4;
				font-size: 1.15em;
			}
			.meta {
				display: flex;
				align-items: baseline;
				gap: 0.8em;
				margin: 0.3em 0 0;
				color: rgb(var(--gray));
				font-size: 0.8em;
			}
			.category {
				color: var(--accent);
			}
			.description {
				margin: 0.3em 0 0;
				color: rgb(var(--gray-dark));
				font-size: 0.9em;
			}
			ul li a:hover .title {
				color: var(--accent-dark);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">全部文章</h1>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={withBase(`/blog/${post.id}/`)}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="meta">
										{post.data.category && <span class="category">{post.data.category}</span>}
										<FormattedDate date={post.data.pubDate} />
									</p>
									<p class="description">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
