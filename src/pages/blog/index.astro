---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, withBase } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`笔记 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-title {
				font-size: 1.1em;
				font-weight: 400;
				color: var(--heading);
				border-bottom: 1px dashed var(--border);
				padding-bottom: 0.5em;
				margin-bottom: 1em;
			}
			.cmd-prefix {
				color: var(--accent);
			}
			ul {
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li + li {
				border-top: 1px dashed var(--border);
			}
			ul li a {
				display: block;
				padding: 0.9em 0.2em;
				text-decoration: none;
			}
			.title {
				margin: 0;
				color: var(--text);
				line-height: 1.5;
				font-size: 1em;
				font-weight: 700;
			}
			.meta {
				margin: 0.2em 0 0;
				color: var(--dim);
				font-size: 0.8em;
			}
			.tags {
				color: var(--accent);
			}
			.description {
				margin: 0.3em 0 0;
				color: var(--dim);
				font-size: 0.9em;
			}
			ul li a:hover .title {
				color: var(--accent);
			}
			.empty {
				color: var(--dim);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title"><span class="cmd-prefix">$</span> ls notes/ --all</h1>
			<section>
				{
					posts.length > 0 ? (
						<ul>
							{posts.map((post) => (
								<li>
									<a href={withBase(`/blog/${post.id}/`)}>
										<h4 class="title">{post.data.title}</h4>
										<p class="meta">
											<FormattedDate date={post.data.pubDate} />
											{post.data.tags.length > 0 && (
												<span class="tags">{post.data.tags.map((t) => `#${t}`).join(' ')}</span>
											)}
										</p>
										<p class="description">{post.data.description}</p>
									</a>
								</li>
							))}
						</ul>
					) : (
						<p class="empty">// 目录为空，第一篇笔记正在路上……</p>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
