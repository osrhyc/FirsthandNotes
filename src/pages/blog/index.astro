---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, withBase } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`笔记 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-head {
				margin-bottom: 1.8em;
			}
			.page-head h1 {
				margin: 0;
			}
			.cards {
				display: flex;
				flex-direction: column;
				gap: 1em;
			}
			.note-card {
				padding: 0.9em 1.2em;
			}
			.top {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1.2em;
			}
			.title {
				margin: 0;
				font-size: 1.02em;
				font-weight: 700;
				line-height: 1.5;
			}
			.date {
				color: var(--faint);
				font-size: 0.8em;
				font-variant-numeric: tabular-nums;
				white-space: nowrap;
			}
			.description {
				margin: 0.25em 0 0;
				color: var(--dim);
				font-size: 0.88em;
			}
			.tags {
				margin: 0.4em 0 0;
				font-size: 0.75em;
				color: var(--accent-text);
			}
			.empty {
				color: var(--dim);
				padding: 0.9em 1.2em;
			}
			@media (max-width: 720px) {
				.top {
					flex-direction: column;
					gap: 0.1em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-head">
				<p class="eyebrow">All Notes</p>
				<h1>全部笔记</h1>
			</div>
			<section>
				{
					posts.length > 0 ? (
						<div class="cards">
							{posts.map((post) => (
								<a class="note-card" href={withBase(`/blog/${post.id}/`)}>
									<div class="top">
										<h4 class="title">{post.data.title}</h4>
										<span class="date">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
									<p class="description">{post.data.description}</p>
									{post.data.tags.length > 0 && (
										<p class="tags">{post.data.tags.map((t) => `#${t}`).join('  ')}</p>
									)}
								</a>
							))}
						</div>
					) : (
						<div class="note-card empty">第一篇笔记正在路上，敬请期待。</div>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
